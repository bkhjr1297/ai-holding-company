.io%2Ffarm-rpg&amp;intent=community" title="Vote up" class="vote_up_btn vote_btn"><svg width="20" height="20" version="1.1" role="img" aria-hidden viewBox="0 0 24 24" class="svgicon icon_vote_up"><polygon points="2 18 12 6 22 18" /></svg></a> <a data-register_action="community_vote" href="https://itch.io/login?return_to=https%3A%2F%2Fmaevedevs.itch.io%2Ffarm-rpg&amp;intent=community" title="Vote down" class="vote_down_btn vote_btn"><svg width="20" height="20" version="1.1" role="img" aria-hidden viewBox="0 0 24 24" class="svgicon icon_vote_down"><polygon points="2 6 12 18 22 6" /></svg></a></div><a class="avatar_container" href="https://itch.io/profile/mhoufc"><div style="background-image: url(/static/images/frog-gold.png)" class="post_avatar"></div></a><div class="post_header"><span class="post_author"><a href="https://itch.io/profile/mhoufc">mhoufc</a></span><span title="2026-04-25 17:00:39" class="post_date"><a href="https://itch.io/post/15960145">60 days ago</a></span> <span class="edit_message">(1 edit)</span> <span class="vote_counts"></span></div><div class="post_content"><div dir="auto" class="post_body user_formatted"><p>I cant seem to find a log sprite for when after chopping down a tree?</p><p><br>I can see wood.png but that&#x27;s in &quot;Farm RPG\Icons\Weapons\All\&quot;<br><br></p></div><div class="post_footer"><a data-register_action="community_reply" href="https://itch.io/login?return_to=https%3A%2F%2Fmaevedevs.itch.io%2Ffarm-rpg&amp;intent=community" class="post_action reply_btn">Reply</a></div></div></div></div><div class="community_post_replies top_level_replies"><div data-post="{&quot;user_id&quot;:6343539,&quot;id&quot;:15960256}" id="post-15960256" class="community_post has_vote_column is_reply has_replies"><div class="post_grid"><div class="post_votes"><a data-register_action="community_vote" href="https://itch.io/login?return_to=https%3A%2F%2Fmaevedevs.itch.io%2Ffarm-rpg&amp;intent=community" title="Vote up" class="vote_up_btn vote_btn"><svg width="20" height="20" version="1.1" role="img" aria-hidden viewBox="0 0 24 24" class="svgicon icon_vote_up"><polygon points="2 18 12 6 22 18" /></svg></a> <a data-register_action="community_vote" href="https://itch.io/login?return_to=https%3A%2F%2Fmaevedevs.itch.io%2Ffarm-rpg&amp;intent=community" title="Vote down" class="vote_down_btn vote_btn"><svg width="20" height="20" version="1.1" role="img" aria-hidden viewBox="0 0 24 24" class="svgicon icon_vote_down"><polygon points="2 6 12 18 22 6" /></svg></a></div><a class="avatar_container" href="https://itch.io/profile/maevedevs"><div style="background-image: url(https://img.itch.zone/aW1nLzI0MTQxNzA5LmpwZw==/25x25%23/IjkjbR.jpg)" class="post_avatar"></div></a><div class="post_header"><span class="post_author"><a href="https://itch.io/profile/maevedevs">Maeve</a></span><span title="2026-04-25 17:30:30" class="post_date"><a href="https://itch.io/post/15960256">60 days ago</a></span><span class="vote_counts"></span></div><div class="post_content"><div dir="auto" class="post_body user_formatted"><p></p><p>You can find it here:<br> <strong>“Farm RPG - Tiny Asset Pack - (All in One)\Farm and Tileset\Tree”</strong></p></div><div class="post_footer"><a data-register_action="community_reply" href="https://itch.io/login?return_to=https%3A%2F%2Fmaevedevs.itch.io%2Ffarm-rpg&amp;intent=community" class="post_action reply_btn">Reply</a></div></div></div></div><div class="community_post_replies"><div data-post="{&quot;user_id&quot;:14610598,&quot;id&quot;:15960284}" id="post-15960284" class="community_post has_vote_column is_reply has_replies"><div class="post_grid"><div class="post_votes"><a data-register_action="community_vote" href="https://itch.io/login?return_to=https%3A%2F%2Fmaevedevs.itch.io%2Ffarm-rpg&amp;intent=community" title="Vote up" class="vote_up_btn vote_btn"><svg width="20" height="20" version="1.1" role="img" aria-hidden viewBox="0 0 24 24" class="svgicon icon_vote_up"><polygon points="2 18 12 6 22 18" /></svg></