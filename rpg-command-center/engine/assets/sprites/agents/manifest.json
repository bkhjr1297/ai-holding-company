    "finance": "pricing.png",
    "pricing": "pricing.png",
    "legal": "legal.png",
    "executive": "executive.png",
    "recruiting": "recruiting.png",
    "builder": "builder.png",
    "default": "field_worker.png",
    "qa": "qa.png",
    "reporter": "reporter.png"
  },
  "role_rules": {
    "Chief of Staff / executive coordinator": "executive.png",
